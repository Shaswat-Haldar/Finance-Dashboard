# Database (Docker local)
DATABASE_URL=postgresql://finance_user:finance_pass@localhost:5432/finance_dashboard

# JWT secret — change this to a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars

# JWT expiration (e.g. 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# API port
PORT=3001

# Frontend origin (for CORS)
CORS_ORIGIN=http://localhost:5173
