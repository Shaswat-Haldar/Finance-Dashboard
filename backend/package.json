{
  "name": "finance-dashboard-api",
  "version": "1.0.0",
  "description": "Hono + Drizzle + PostgreSQL backend for Zuvlyn Finance Dashboard",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
